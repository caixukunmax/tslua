# =============================================================================
# Git 换行符配置 - 确保跨平台一致性
# Windows 开发，Linux 容器运行，必须统一使用 LF
# =============================================================================

# 自动处理换行符（检出时转换，提交时统一为 LF）
* text=auto eol=lf

# 脚本文件强制使用 LF（容器内执行必须）
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Lua 文件强制使用 LF
*.lua text eol=lf

# Docker 相关文件
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
.dockerignore text eol=lf

# 配置文件
*.conf text eol=lf
*.config text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.toml text eol=lf

# 源码文件
*.ts text eol=lf
*.js text eol=lf
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.go text eol=lf
*.rs text eol=lf
*.java text eol=lf
*.py text eol=lf

# 文档
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# 标记文件（标记文件不应被修改）
*.lock text eol=lf

# 二进制文件（Git 不应处理换行符）
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.bin binary
*.pyc binary
*.class binary
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar binary
*.gz binary
*.rar binary
*.7z binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.bmp binary
*.ico binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
