{
  "name": "ts-skynet-hybrid",
  "version": "1.0.0",
  "description": "TS-Skynet Hybrid Development Framework - TypeScript to Skynet Lua Runtime",
  "main": "dist/nodejs/index.js",
  "scripts": {
    "cli": "tsx scripts/cli/index.ts",
    "menu": "npm run cli",
    "dev": "ts-node src/app/bootstrap-node.ts",
    "build": "npm run cli -- build:all",
    "build:ts": "npx tstl --project config/tsconfig.lua.json",
    "build:ts:watch": "npx tstl --watch",
    "build:proto": "cd ../protocols && npm run build",
    "build:tables": "cd ../tables && npm run build",
    "server:start": "npm run cli -- start",
    "server:stop": "npm run cli -- stop",
    "server:restart": "npm run cli -- restart",
    "server:status": "npm run cli -- status",
    "server:logs": "npm run cli -- logs",
    "hotfix": "npm run cli -- hotfix",
    "setup": "npm run cli -- setup",
    "quick": "npm run cli -- quick",
    "clean": "npm run cli -- build:clean"
  },
  "keywords": [
    "typescript",
    "skynet",
    "lua",
    "game-server",
    "actor-model"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "lua-types": "^2.13.1",
    "ts-node": "^10.9.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "typescript-to-lua": "^1.33.2"
  }
}
