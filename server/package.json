{
  "name": "ts-skynet-hybrid",
  "version": "1.0.0",
  "description": "TS-Skynet Hybrid Development Framework - TypeScript to Skynet Lua Runtime",
  "main": "dist/nodejs/index.js",
  "scripts": {
    "dev": "ts-node src/app/bootstrap-node.ts",
    "dev:node": "npm-run-all -p dev:node:*",
    "dev:node:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev.ps1 node",
    "dev:node:unix": "./scripts/dev.sh node",
    "dev:up": "npm run dev:up:unix",
    "dev:up:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev.ps1 up",
    "dev:up:unix": "./scripts/dev.sh up",
    "dev:up:daemon": "npm run dev:up:daemon:unix",
    "dev:up:daemon:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev.ps1 up:daemon",
    "dev:up:daemon:unix": "./scripts/dev.sh up:daemon",
    "build": "npm run build:unix",
    "build:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build.ps1 all",
    "build:unix": "./scripts/build.sh all",
    "build:ts": "npm run build:ts:unix",
    "build:ts:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build.ps1 ts",
    "build:ts:unix": "./scripts/build.sh ts",
    "build:ts:watch": "npm run build:ts:watch:unix",
    "build:ts:watch:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build.ps1 ts:watch",
    "build:ts:watch:unix": "./scripts/build.sh ts:watch",
    "build:engine": "./scripts/build.sh engine",
    "build:proto": "cd ../protocols && npm run build",
    "build:tables": "cd ../tables && npm run build",
    "build:clean": "npm run build:clean:unix",
    "build:clean:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build.ps1 clean",
    "build:clean:unix": "./scripts/build.sh clean",
    "server:start": "npm run server:start:unix",
    "server:start:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start.ps1 start",
    "server:start:unix": "./scripts/start.sh start",
    "server:start:daemon": "npm run server:start:daemon:unix",
    "server:start:daemon:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start.ps1 start -Daemon",
    "server:start:daemon:unix": "./scripts/server.sh start -d",
    "server:stop": "npm run server:stop:unix",
    "server:stop:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start.ps1 stop",
    "server:stop:unix": "./scripts/server.sh stop",
    "server:restart": "npm run server:restart:unix",
    "server:restart:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start.ps1 restart",
    "server:restart:unix": "./scripts/server.sh restart",
    "server:status": "npm run server:status:unix",
    "server:status:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start.ps1 status",
    "server:status:unix": "./scripts/server.sh status",
    "hotfix": "npm run hotfix:unix",
    "hotfix:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev.ps1 hotfix",
    "hotfix:unix": "./scripts/dev.sh hotfix",
    "setup": "npm run setup:unix",
    "setup:win32": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev.ps1 setup",
    "setup:unix": "./scripts/dev.sh setup"
  },
  "keywords": [
    "typescript",
    "skynet",
    "lua",
    "game-server",
    "actor-model"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "lua-types": "^2.13.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "typescript-to-lua": "^1.33.2"
  }
}
