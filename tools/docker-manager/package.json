{
  "name": "tslua-docker-manager",
  "version": "1.0.0",
  "description": "TS-Skynet Docker 容器管理工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "node-ssh": "^13.1.0",
    "chokidar": "^3.5.3"
  },
  "build": {
    "appId": "com.tslua.docker-manager",
    "productName": "TS-Skynet Docker 管理器",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
