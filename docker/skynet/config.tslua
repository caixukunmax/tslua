-- TS-Skynet 混合项目配置文件

-- 线程数
thread = 8

-- 日志文件
-- logger = "userlog"

-- 启动模块（snlua 用于加载 Lua 服务）
bootstrap = "snlua bootstrap"

-- 启动脚本路径
start = "ts_bootstrap"

-- Lua 代码路径
luaservice = "./service/?.lua;../dist/lua/?.lua"
lualoader = "./lualib/loader.lua"

-- Lua cpath
lua_path = "./lualib/?.lua;./lualib/?/init.lua;../dist/lua/?.lua"
lua_cpath = "./luaclib/?.so"

-- C 服务路径
cpath = "./cservice/?.so"

-- 守护进程（0 = 不后台运行，方便调试）
daemon = nil

-- Harbor ID (单节点为 0)
harbor = 0
