{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Luban 配置表编译配置",
  "description": "配置 Luban 源文件目录和输出目录",
  "luban_dll": "tools/luban/Luban/Luban.dll",
  "input": {
    "data_dir": "datas",
    "define_dir": "defines",
    "config_file": "luban.conf"
  },
  "output": {
    "code_dir": "../server/src/tables",
    "data_dir": "../server/src/tables/data",
    "targets": [
      {
        "name": "lua",
        "code_type": "lua-lua",
        "data_type": "lua",
        "enabled": true
      },
      {
        "name": "json",
        "code_type": "lua",
        "data_type": "json",
        "enabled": true
      }
    ]
  },
  "luban_args": {
    "l10n_text_provider_file": "datas/l10n/texts.json"
  }
}
