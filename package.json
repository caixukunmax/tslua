{
  "name": "ts-skynet-hybrid",
  "version": "1.0.0",
  "description": "TS-Skynet Hybrid Development Framework - TypeScript to Skynet Lua Runtime",
  "private": true,
  "workspaces": [
    "server",
    "protocols",
    "tables"
  ],
  "scripts": {
    "cli": "cd server && npm run cli",
    "menu": "npm run cli",
    "dev": "cd server && npm run dev",
    "build": "cd server && npm run build",
    "build:ts": "cd server && npm run build:ts",
    "build:ts:watch": "cd server && npm run build:ts:watch",
    "build:proto": "cd protocols && npm run build",
    "build:tables": "cd tables && npm run build",
    "server:start": "cd server && npm run server:start",
    "server:stop": "cd server && npm run server:stop",
    "server:restart": "cd server && npm run server:restart",
    "server:status": "cd server && npm run server:status",
    "server:logs": "cd server && npm run server:logs",
    "hotfix": "cd server && npm run hotfix",
    "setup": "cd server && npm run setup",
    "quick": "cd server && npm run quick",
    "clean": "cd server && npm run clean",
    "docker:manage": "node tools/docker-cli/index.js",
    "docker:init": "node tools/docker-cli/index.js --init"
  },
  "keywords": [
    "typescript",
    "skynet",
    "lua",
    "game-server",
    "actor-model"
  ],
  "author": "",
  "license": "MIT"
}
