{
  "name": "ts-skynet-hybrid",
  "version": "1.0.0",
  "description": "TS-Skynet Hybrid Development Framework - TypeScript to Skynet Lua Runtime",
  "main": "dist/nodejs/index.js",
  "scripts": {
    "dev": "ts-node src/app/bootstrap-node.ts",
    "dev:node": "./scripts/dev.sh node",
    "dev:up": "./scripts/dev.sh up",
    "dev:up:daemon": "./scripts/dev.sh up:daemon",
    "build": "./scripts/build.sh all",
    "build:ts": "./scripts/build.sh ts",
    "build:ts:watch": "./scripts/build.sh ts:watch",
    "build:engine": "./scripts/build.sh engine",
    "build:proto": "./scripts/build_proto.sh",
    "build:clean": "./scripts/build.sh clean",
    "server:start": "./scripts/server.sh start",
    "server:start:daemon": "./scripts/server.sh start -d",
    "server:stop": "./scripts/server.sh stop",
    "server:restart": "./scripts/server.sh restart",
    "server:status": "./scripts/server.sh status",
    "hotfix": "./scripts/dev.sh hotfix",
